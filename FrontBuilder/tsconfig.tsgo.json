{
  "//": "Type-check config for tsgo (@typescript/native-preview / TS 7). The",
  "//2": "native compiler dropped legacy options (baseUrl, moduleResolution=node10)",
  "//3": "that the rspack/ts-node tsconfig.json still uses, so type-checking has",
  "//4": "its own modern config. Covers the framework frontend (../Bundle/Front)",
  "//5": "plus FrontBuilder's own build sources.",
  "compilerOptions": {
    "skipLibCheck": true,
    "allowJs": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["web"],
    "noEmit": true,
    "strict": false,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "paths": {
      "@common/*": ["../Bundle/Front/Common/*"],
      "@framework/*": ["../Bundle/Front/*"],
      "gridjs/dist/src/types": ["./node_modules/gridjs/dist/src/types"]
    },
    "target": "esnext"
  },
  "exclude": ["node_modules", "dist", "build"],
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../Bundle/Front/**/*.ts",
    "../Bundle/Front/**/*.tsx"
  ]
}
