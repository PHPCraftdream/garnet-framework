{% extends 'layout.twig' %}

{% block content %}
<div class="flex items-center justify-center min-h-screen">
    <div class="bg-white rounded-lg shadow-lg p-8 max-w-md w-full text-center">
        <h1 class="text-2xl font-bold mb-4">Garnet Admin</h1>
        <p class="text-gray-600 mb-4">Run the following command in your terminal to get access:</p>
        <code class="block bg-gray-100 rounded p-3 text-sm font-mono">php garnet admin</code>
        <p class="text-gray-400 text-sm mt-4">Then open the URL it prints.</p>
    </div>
</div>
{% endblock %}
