# Garnet App Environment Configuration
# Copy this file to .env and fill in the values for your environment.

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=Application
APP_ENV=development
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_BASE_URL=http://localhost:8001
APP_TITLE=My App
APP_DESCRIPTION=A Garnet framework application

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=myapp_dev
DB_USER=root
DB_PASS=

# ─── Email ────────────────────────────────────────────────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# ─── Paths ────────────────────────────────────────────────────────────────────
PUBLIC_DIR=./Public
UPLOAD_DIR=./WorkDir/Upload

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_EMAILS=admin@example.com
