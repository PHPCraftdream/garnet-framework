#!/usr/bin/env php
<?php declare(strict_types=1);

// One-shot Garnet application installer.
//
// Unlike `garnet app:create` (which assumes the framework is already a
// project dependency), this script has ZERO coupling to any framework
// version: it pulls whichever version/channel is requested into a throwaway
// bootstrap directory via a real `composer require`, invokes the
// framework's own scaffolding command from there, then discards the
// bootstrap. The generated app ends up with its own independent
// `phpcraftdream/garnet-framework` dependency (see GarnetAppCommand's
// dev-checkout vs release-install detection) — nothing here hardcodes a
// framework version, so this installer needs no changes when a new
// stable release ships.
//
// Usage:
//   garnet-new <AppName> [--target=<dir>] [--version=<constraint>]
//              [--channel=dev|alpha|beta|stable] [--no-install] [--quiet]
//
// Version resolution (in priority order):
//   --version=<constraint>   Explicit Composer constraint, e.g. "^0.2",
//                             "dev-master", "^0.1.0-alpha3".
//   --channel=<name>         Shorthand for a stability channel:
//                               dev    -> dev-master
//                               alpha  -> ^0.1@alpha
//                               beta   -> ^0.1@beta
//                               stable -> ^0.1@stable
//   (none)                    "^0.1" with Composer's default stability
//                             policy (stable-only) — i.e. "latest stable".
//                             Once a real stable 0.1.x/1.x ships, this
//                             resolves correctly with no installer changes.

if (php_sapi_name() !== 'cli') {
    echo 'CLI only.' . PHP_EOL;
    exit(1);
}

$args = array_slice($argv, 1);
$name = null;
$target = '';
$constraint = null;
$noInstall = false;
$quiet = false;

foreach ($args as $arg) {
    if (str_starts_with($arg, '--target=')) {
        $target = trim(substr($arg, 9), " \t\"'");
    } elseif (str_starts_with($arg, '--version=')) {
        $constraint = trim(substr($arg, 10), " \t\"'");
    } elseif (str_starts_with($arg, '--channel=')) {
        $channel = trim(substr($arg, 10), " \t\"'");
        $constraint = match ($channel) {
            'dev' => 'dev-master',
            'alpha' => '^0.1@alpha',
            'beta' => '^0.1@beta',
            'stable' => '^0.1@stable',
            default => null,
        };

        if ($constraint === null) {
            fwrite(STDERR, "Unknown --channel: {$channel} (expected dev|alpha|beta|stable)" . PHP_EOL);
            exit(1);
        }
    } elseif ($arg === '--no-install') {
        $noInstall = true;
    } elseif ($arg === '--quiet' || $arg === '-q') {
        $quiet = true;
    } elseif ($name === null && !str_starts_with($arg, '-')) {
        $name = $arg;
    }
}

if ($name === null) {
    echo 'Usage: garnet-new <AppName> [--target=<dir>] [--version=<constraint>] [--channel=dev|alpha|beta|stable] [--no-install] [--quiet]' . PHP_EOL;
    exit(1);
}

// Default: latest stable, via Composer's own stability resolution — no
// version is hardcoded here, so this stays correct forever.
$constraint ??= '^0.1';

$ds = DIRECTORY_SEPARATOR;
$bootstrap = sys_get_temp_dir() . $ds . 'garnet-installer-' . bin2hex(random_bytes(6));

if (!mkdir($bootstrap, 0o755, true) && !is_dir($bootstrap)) {
    fwrite(STDERR, "Could not create temp bootstrap dir: {$bootstrap}" . PHP_EOL);
    exit(1);
}

// A dev-stability constraint (dev-master, @dev, etc.) makes GarnetAppCommand
// wire a path-repository straight into this bootstrap dir instead of pinning
// a version (see installedReleaseVersion()'s dev-checkout detection) — the
// generated app would keep depending on it. Only auto-clean up for a real
// tagged release, where the app gets its own independent Packagist
// dependency and the bootstrap is genuinely disposable.
$isDevConstraint = str_starts_with($constraint, 'dev-') || str_contains($constraint, '-dev') || str_contains($constraint, '@dev');

if (!$isDevConstraint) {
    register_shutdown_function(static function () use ($bootstrap): void {
        removeDirectory($bootstrap);
    });
} else {
    register_shutdown_function(static function () use ($bootstrap): void {
        echo PHP_EOL . "Note: --channel=dev keeps a live path-repository into the bootstrap dir — not cleaning it up:" . PHP_EOL;
        echo "  {$bootstrap}" . PHP_EOL;
    });
}

file_put_contents(
    $bootstrap . $ds . 'composer.json',
    json_encode(
        [
            'name' => 'garnet/installer-bootstrap',
            'type' => 'project',
            'require' => ['phpcraftdream/garnet-framework' => $constraint],
        ],
        JSON_PRETTY_PRINT | JSON_UNESCAPED_SLASHES,
    ) . "\n",
);

if (!$quiet) {
    echo "Fetching phpcraftdream/garnet-framework ({$constraint})…" . PHP_EOL;
}

$requireCmd = sprintf(
    'composer require %s --no-interaction --working-dir=%s%s',
    escapeshellarg('phpcraftdream/garnet-framework:' . $constraint),
    escapeshellarg($bootstrap),
    $quiet ? ' --quiet' : '',
);

passthru($requireCmd, $code);

if ($code !== 0) {
    fwrite(STDERR, PHP_EOL . "Could not resolve phpcraftdream/garnet-framework:{$constraint}." . PHP_EOL);
    fwrite(STDERR, 'If no stable release exists yet, try --channel=alpha or an explicit --version=.' . PHP_EOL);
    exit($code);
}

$autoload = $bootstrap . $ds . 'vendor' . $ds . 'autoload.php';

if (!file_exists($autoload)) {
    fwrite(STDERR, "Bootstrap install succeeded but autoload not found at {$autoload}" . PHP_EOL);
    exit(1);
}

require_once $autoload;

// The framework's GarnetRunner::boot() is not called in installer context,
// so GARNET_ROOT constant and GarnetRunner::$frameworkDir are unset.
// Point both at the freshly-installed framework package so that
// GarnetAppCommand can find Templates/ and detect release vs dev mode.
$frameworkPath = $bootstrap . $ds . 'vendor' . $ds . 'phpcraftdream' . $ds . 'garnet-framework';
\PHPCraftdream\Garnet\Kernel\Io\GarnetCli\GarnetRunner::$frameworkDir = $frameworkPath;

if (!defined('GARNET_ROOT')) {
    define('GARNET_ROOT', $frameworkPath);
}

$createArgs = [$name];

if ($target !== '') {
    $createArgs[] = '--target=' . $target;
}

if ($noInstall) {
    $createArgs[] = '--no-install';
}

if ($quiet) {
    $createArgs[] = '--quiet';
}

\PHPCraftdream\Garnet\Kernel\Io\GarnetCli\GarnetAppCommand::run('app:create', $createArgs);

/** Best-effort recursive delete of the ephemeral bootstrap dir. */
function removeDirectory(string $dir): void {
    if (!is_dir($dir)) {
        return;
    }

    $items = @scandir($dir);

    if ($items === false) {
        return;
    }

    foreach ($items as $item) {
        if ($item === '.' || $item === '..') {
            continue;
        }

        $path = $dir . DIRECTORY_SEPARATOR . $item;

        if (is_link($path) || is_file($path)) {
            @unlink($path);
        } elseif (is_dir($path)) {
            removeDirectory($path);
        }
    }

    @rmdir($dir);
}
